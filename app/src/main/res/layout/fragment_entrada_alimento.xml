<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registro Directo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/edtNombreAlimento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nombre del Alimento" />

        <EditText
            android:id="@+id/edtTipoComida"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tipo de Comida" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <EditText
                android:id="@+id/edtCantidad"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Cantidad (g)"
                android:inputType="numberDecimal" />
            <EditText
                android:id="@+id/edtHoraConsumo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Hora (HH:mm)" />
        </LinearLayout>

        <EditText
            android:id="@+id/edtCalorias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Calorías Totales"
            android:inputType="numberDecimal" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/edtProteinas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Prot"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/edtCarbohidratos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Carb"
                android:inputType="numberDecimal" />

            <EditText
                android:id="@+id/edtGrasa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Grasa"
                android:inputType="numberDecimal" />
        </LinearLayout>

        <Button
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Guardar" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>